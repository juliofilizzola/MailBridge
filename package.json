{
  "name": "mail-bridge",
  "version": "1.0.0",
  "main": "dist/index.js",
  "repository": "git@github.com:juliofilizzola/MailBridge.git",
  "author": "julio filizzola <juliofilizzola@hotmail.com>",
  "license": "MIT",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "security:check": "yarn audit --groups dependencies"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.1",
    "@types/nodemailer": "8.0.0",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "prettier": "3.8.3",
    "tsc-alias": "1.8.17",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "3.1056.0",
    "@sendgrid/mail": "8.1.6",
    "dotenv": "17.4.2",
    "nodemailer": "8.0.9"
  }
}
